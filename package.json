{
	"name": "html-to-pdf-frontend",
	"private": true,
	"version": "0.6.0",
	"engines": {
		"node": ">=22.22.2"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
