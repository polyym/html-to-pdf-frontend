	},
	"devDependencies": {
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.8"
	},
	"dependencies": {
		"@sveltejs/adapter-netlify": "^6.0.4"
	}
}
